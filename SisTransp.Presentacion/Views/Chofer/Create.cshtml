@model SisTransp.Dominio.Entidades.Chofer

@{
    ViewBag.Title = "Nuevo Chofer";
}

<div class="container-fluid">
    <div class="card">
        <div class="card-header">
            <h4>Registrar Nuevo Chofer</h4>
        </div>

        <div class="card-body">
            @using (Html.BeginForm())
            {
                @Html.ValidationSummary(true, "", new { @class = "text-danger" })

                <div class="row">
                    <div class="col-md-6">
                        <label>Nombre completo</label>
                        @Html.TextBoxFor(x => x.NombreCompleto, new { @class = "form-control" })
                        @Html.ValidationMessageFor(x => x.NombreCompleto, "", new { @class = "text-danger" })
                    </div>


                    <div class="col-md-3">
                        <label>Licencia</label>
                        @Html.TextBoxFor(x => x.Licencia, new { @class = "form-control" })
                        @Html.ValidationMessageFor(x => x.Licencia, "", new { @class = "text-danger" })
                    </div>

                    <div class="col-md-3">
                        <label>Teléfono</label>
                        @Html.TextBoxFor(x => x.Telefono, new { @class = "form-control" })
                        @Html.ValidationMessageFor(x => x.Telefono, "", new { @class = "text-danger" })
                    </div>
                </div>

                <br />

                <button class="btn btn-danger">
                    Guardar
                </button>


                <a href="/Chofer" class="btn btn-secondary">
                    Volver
                </a>
            }
        </div>
    </div>
</div>

@section Scripts{
    @Scripts.Render("~/bundles/jqueryval")
}