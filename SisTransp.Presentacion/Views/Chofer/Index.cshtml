@model IEnumerable<SisTransp.Dominio.Entidades.Chofer>

@{
    ViewBag.Title = "Gestión de Choferes";
}

<div class="container-fluid">

    <div class="card shadow">

        <div class="card-header bg-dark text-white">

            <div class="row">

                <div class="col-md-8">
                    <h3>Gestión de Choferes</h3>
                </div>

                <div class="col-md-4 text-end">

                    <a href="/Chofer/Create"
                       class="btn btn-success">
                        + Nuevo Chofer
                    </a>

                </div>

            </div>

        </div>

        <div class="card-body">
            <div class="col-md-4 mb-3">
                <input type="text" id="buscarTabla" class="form-control" placeholder="Buscar..." />
            </div>
            <table class="table table-hover align-middle">

                <thead style="background:#B71C1C;color:white">

                    <tr>

                        <th>ID</th>
                        <th>Chofer</th>
                        <th>Licencia</th>
                        <th>Teléfono</th>
                        <th>Estado</th>
                        <th width="250">
                            Acciones
                        </th>

                    </tr>

                </thead>


                <tbody>

                    @foreach (var item in Model)
                    {
                        <tr>

                            <td>@item.IdChofer</td>

                            <td>@item.NombreCompleto</td>

                            <td>@item.Licencia</td>

                            <td>@item.Telefono</td>

                            <td>

                                @if (item.Estado)
                                {
                                    <span class="badge bg-success">
                                        Activo
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">
                                        Inactivo
                                    </span>
                                }

                            </td>


                            <td>

                                <div class="btn-group">

                                    <a href="/Chofer/Edit/@item.IdChofer"
                                       class="btn btn-warning btn-sm">

                                        Editar

                                    </a>

                                    <a href="/Chofer/Details/@item.IdChofer"
                                       class="btn btn-info btn-sm">

                                        Ver

                                    </a>

                                    <a href="/Chofer/Delete/@item.IdChofer"
                                       class="btn btn-danger btn-sm"
                                       onclick="return confirm('¿Eliminar chofer?')">

                                        Eliminar

                                    </a>

                                </div>

                            </td>

                        </tr>

                    }

                </tbody>

            </table>

        </div>

    </div>

</div>

@section scripts{
    <script>
        $("#buscarTabla").on("keyup", function () {
            var valor = $(this).val().toLowerCase();

            $("table tbody tr").filter(function () {
                $(this).toggle($(this).text().toLowerCase().indexOf(valor) > -1);
            });
        });
    </script>
}