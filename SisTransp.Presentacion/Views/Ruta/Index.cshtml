@model IEnumerable<SisTransp.Dominio.Entidades.Ruta>

@{
    ViewBag.Title = "Gestión de Rutas";
}

<div class="container-fluid">

    <div class="card">

        <div class="card-header">

            <div class="row">

                <div class="col-md-8">
                    <h3>Gestión de Rutas</h3>
                </div>

                <div class="col-md-4 text-end">
                    <a href="/Ruta/Create" class="btn btn-light">
                        + Nueva Ruta
                    </a>
                </div>

            </div>

        </div>

        <div class="card-body">
            <div class="col-md-4 mb-3">
                <input type="text" id="buscarTabla" class="form-control" placeholder="Buscar..." />
            </div>
            <table class="table table-hover">

                <thead style="background:#B71C1C;color:white">

                    <tr>
                        <th>ID</th>
                        <th>Origen</th>
                        <th>Destino</th>
                        <th>Distancia Km</th>
                        <th>Estado</th>
                        <th width="250">Acciones</th>
                    </tr>

                </thead>

                <tbody>

                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.IdRuta</td>
                            <td>@item.Origen</td>
                            <td>@item.Destino</td>
                            <td>@item.DistanciaKm Km</td>

                            <td>
                                @if (item.Estado)
                                {
                                    <span class="badge bg-success">Activo</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Inactivo</span>
                                }
                            </td>

                            <td>
                                <div class="btn-group">

                                    <a href="/Ruta/Edit/@item.IdRuta"
                                       class="btn btn-warning btn-sm">
                                        Editar
                                    </a>

                                    <a href="/Ruta/Details/@item.IdRuta"
                                       class="btn btn-info btn-sm">
                                        Ver
                                    </a>

                                    <a href="/Ruta/Delete/@item.IdRuta"
                                       onclick="return confirm('¿Eliminar ruta?')"
                                       class="btn btn-danger btn-sm">
                                        Eliminar
                                    </a>

                                </div>
                            </td>
                        </tr>
                    }

                </tbody>

            </table>

        </div>

    </div>

</div>
@section scripts{
    <script>
        $("#buscarTabla").on("keyup", function () {
            var valor = $(this).val().toLowerCase();

            $("table tbody tr").filter(function () {
                $(this).toggle($(this).text().toLowerCase().indexOf(valor) > -1);
            });
        });
    </script>
}